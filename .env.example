# Groq powers the natural language concierge responses.
# Set this locally, do not paste your real key into chat.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Booking notifications. SMTP is the simplest production-ready path.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Suzana Ali & Partners <appointments@suzanaali.com>"

# Partner notification recipients. Replace with direct partner emails if available.
SUZANA_EMAIL=admin.kl@suzanaali.com
SHAHRIMAN_EMAIL=admin.kl@suzanaali.com
NUR_FARAHIZZAH_EMAIL=admin.ns@suzanaali.com

NEXT_PUBLIC_SITE_URL=http://localhost:3000
